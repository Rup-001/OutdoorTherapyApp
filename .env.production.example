# -----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT VARIABLES (EC2 SETUP)
# -----------------------------------------------------------------------------
# Ei file ta EC2 server-e '.env' name-e save koro ~/app/Bankend folder-e.

NODE_ENV=production
PORT=8000

# --- Database (Supabase) ---
# Use the connection string from Supabase Settings > Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres"

# --- Security ---
JWT_SECRET="generate-a-very-long-random-string-here"
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30

# --- Storage (Cloudflare R2) ---
STORAGE_MODE=s3
S3_ACCESS_KEY="your-r2-access-key"
S3_SECRET_KEY="your-r2-secret-key"
S3_BUCKET_NAME="your-bucket-name"
S3_REGION="auto"
S3_ENDPOINT="https://[YOUR-ACCOUNT-ID].r2.cloudflarestorage.com"

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="https://yourdomain.com/success"
STRIPE_CANCEL_URL="https://yourdomain.com/cancel"

# --- Email (SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="no-reply@yourdomain.com"

# --- Frontend Domains ---
BACKEND_IP="your-ec2-public-ip"
IMAGE_UPLOAD_BACKEND_DOMAIN="https://api.yourdomain.com"
