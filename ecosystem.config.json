{
  "apps": [
    {
      "name": "music-backend",
      "script": "src/index.js",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "development"
      },
      "env_production": {
        "NODE_ENV": "production"
      },
      "watch": false,
      "max_memory_restart": "1G",
      "error_file": "app.log",
      "out_file": "app.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    }
  ]
}
